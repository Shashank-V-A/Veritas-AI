{
  "name": "veritas-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently -n frontend,backend -c cyan,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=@veritas/backend",
    "build": "npm run build --workspace=@veritas/shared && npm run build --workspace=@veritas/backend && npm run build --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=@veritas/backend",
    "postinstall": "npm run db:generate --workspace=@veritas/backend",
    "db:push": "npm run db:push --workspace=@veritas/backend",
    "db:studio": "npm run db:studio --workspace=@veritas/backend",
    "lint": "npm run lint --workspace=frontend",
    "vercel-build": "npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String            @id @default(uuid())
  googleId      String            @unique
  email         String            @unique
  name          String?
  avatar        String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  analyses      Analysis[]
  annotations   CaseAnnotation[]
  watches       ClaimWatch[]
  exhibits      CaseExhibit[]
  feedback      VerdictFeedback[]
  notifications Notification[]
}

model Analysis {
  id            String            @id @default(uuid())
  title         String?
  content       String
  sourceType    String            @default("raw")
  sourceUrl     String?
  trustScore    Int
  report        String
  userId        String?
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  shareToken    String?           @unique
  category      String?
  parentId      String?
  meshModel     String?
  meshLatencyMs Int?
  forwardRisk   Int?
  verdict       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  annotations   CaseAnnotation[]
  exhibits      CaseExhibit[]
  feedback      VerdictFeedback[]
  watches       ClaimWatch[]

  @@index([createdAt])
  @@index([trustScore])
  @@index([userId])
  @@index([shareToken])
  @@index([category])
  @@index([verdict])
  @@index([sourceUrl])
}

model DomainReputation {
  domain        String   @id
  caseCount     Int      @default(0)
  lowTrustCount Int      @default(0)
  avgTrustScore Float    @default(0)
  updatedAt     DateTime @updatedAt
}

model CaseAnnotation {
  id         String   @id @default(uuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  claimIndex Int?
  note       String
  createdAt  DateTime @default(now())

  @@index([analysisId])
}

model ClaimWatch {
  id                String          @id @default(uuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  claimText         String
  claimNorm         String
  sourceAnalysisId  String?
  sourceAnalysis    Analysis?       @relation(fields: [sourceAnalysisId], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())
  lastSeenAt        DateTime?
  hitCount          Int             @default(0)
  lastHitAnalysisId String?
  emailAlerts       Boolean         @default(true)
  browserAlerts     Boolean         @default(true)
  lastWebScanAt     DateTime?
  webHitCount       Int             @default(0)
  hits              ClaimWatchHit[]

  @@unique([userId, claimNorm])
  @@index([userId, claimNorm])
}

model ClaimWatchHit {
  id           String     @id @default(uuid())
  watchId      String
  watch        ClaimWatch @relation(fields: [watchId], references: [id], onDelete: Cascade)
  source       String
  title        String?
  url          String?
  snippet      String?
  analysisId   String?
  discoveredAt DateTime   @default(now())

  @@index([watchId, discoveredAt])
  @@index([watchId, source])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  href      String?
  meta      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model CaseExhibit {
  id         String   @id @default(uuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String?
  url        String?
  note       String?
  createdAt  DateTime @default(now())

  @@index([analysisId])
  @@index([userId])
}

model VerdictFeedback {
  id               String   @id @default(uuid())
  analysisId       String
  analysis         Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalVerdict  String
  suggestedVerdict String?
  reason           String?
  createdAt        DateTime @default(now())

  @@unique([analysisId, userId])
  @@index([analysisId])
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String           @id @default(uuid())
  googleId    String           @unique
  email       String           @unique
  name        String?
  avatar      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  analyses    Analysis[]
  annotations CaseAnnotation[]
}

model Analysis {
  id            String   @id @default(uuid())
  title         String?
  content       String
  sourceType    String   @default("raw")
  sourceUrl     String?
  trustScore    Int
  report        String
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  shareToken    String?  @unique
  category      String?
  parentId      String?
  meshModel     String?
  meshLatencyMs Int?
  forwardRisk   Int?
  verdict       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  annotations   CaseAnnotation[]

  @@index([createdAt])
  @@index([trustScore])
  @@index([userId])
  @@index([shareToken])
  @@index([category])
  @@index([verdict])
  @@index([sourceUrl])
}

model DomainReputation {
  domain        String   @id
  caseCount     Int      @default(0)
  lowTrustCount Int      @default(0)
  avgTrustScore Float    @default(0)
  updatedAt     DateTime @updatedAt
}

model CaseAnnotation {
  id         String   @id @default(uuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  claimIndex Int?
  note       String
  createdAt  DateTime @default(now())

  @@index([analysisId])
}

# Database
# Local development:
DATABASE_URL="file:./dev.db"
# Vercel production (ephemeral — resets on cold starts):
# DATABASE_URL="file:/tmp/veritas.db"

# Mesh API (server-side only — never expose to frontend)
MESH_API_KEY=your_mesh_api_key_here
MESH_API_URL=https://api.meshapi.ai
MESH_MODEL=google/gemini-2.5-flash
# MESH_USE_STUB=true

# Google OAuth (server-side only)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Local dev (via Vite proxy):
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
# Production:
# GOOGLE_CALLBACK_URL=https://your-domain.vercel.app/api/auth/google/callback

# Session signing secret (generate a long random string)
JWT_SECRET=your_jwt_secret_here

# Frontend URL for OAuth redirect after sign-in
FRONTEND_URL=http://localhost:5173

# Frontend (build-time — set in Vercel project settings)
VITE_API_BASE_URL=/api

# Optional: custom production frontend URL for CORS
# FRONTEND_URL=https://your-domain.com

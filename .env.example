# Database
# Local development:
DATABASE_URL="file:./dev.db"
# Turso (production — persistent):
# DATABASE_URL="libsql://your-db-name-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-token"
# Quick setup on Vercel: `npx vercel integration add turso` (accept terms in browser)
# Vercel ephemeral fallback:
# DATABASE_URL="file:/tmp/veritas.db"

# Mesh API (server-side only — never expose to frontend)
MESH_API_KEY=your_mesh_api_key_here
MESH_API_URL=https://api.meshapi.ai
MESH_MODEL=google/gemini-2.5-flash
# MESH_USE_STUB=true

# Web search (optional — improves suggestedReading URLs + watchlist web scan)
# TAVILY_API_KEY=tvly-...

# Watchlist email alerts (optional — Resend)
# RESEND_API_KEY=re_...
# EMAIL_FROM="Veritas AI <alerts@yourdomain.com>"

# YouTube transcripts on Vercel
# YouTube blocks caption downloads from cloud IPs. Free options:
# 1) GEMINI_API_KEY from https://aistudio.google.com/apikey (recommended, free)
# 2) SUPADATA_API_KEY from https://supadata.ai (100 free / month)
# Optional residential Webshare rotating gateway (NOT datacenter ip:port lists):
# WEBSHARE_PROXY_USERNAME=...
# WEBSHARE_PROXY_PASSWORD=...

# Cron auth for scheduled watchlist web scans (Vercel Cron)
# CRON_SECRET=generate_a_long_random_string

# Google OAuth (server-side only)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback

# Session signing secret (generate a long random string)
JWT_SECRET=your_jwt_secret_here

# Frontend URL for OAuth redirect after sign-in
FRONTEND_URL=http://localhost:5173

# Public app URL for share links + OG images
PUBLIC_APP_URL=http://localhost:5173

# Neo4j knowledge graph (optional)
# Paste values from the Aura credentials download (.txt)
# NEO4J_URI=neo4j+s://YOUR_INSTANCE_ID.databases.neo4j.io
# NEO4J_USERNAME=YOUR_INSTANCE_ID
# NEO4J_PASSWORD=your_aura_password
# NEO4J_DATABASE=YOUR_INSTANCE_ID

# Frontend (build-time)
VITE_API_BASE_URL=/api

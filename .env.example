# Database
# Local development:
DATABASE_URL="file:./dev.db"
# Vercel production (ephemeral — resets on cold starts):
# DATABASE_URL="file:/tmp/veritas.db"

# Mesh API (server-side only — never expose to frontend)
MESH_API_KEY=your_mesh_api_key_here
MESH_API_URL=https://api.meshapi.ai
MESH_MODEL=google/gemini-2.5-flash
# MESH_USE_STUB=true

# Frontend (build-time — set in Vercel project settings)
VITE_API_BASE_URL=/api

# Optional: custom production frontend URL for CORS
# FRONTEND_URL=https://your-domain.com
